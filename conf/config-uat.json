{
    "application": {
        "name": "SMS Sender",
        "version": "1.0.0",
        "environment": "UAT"
    },

    "input": {
        "delimiter": ",",
        "has_header": false,
        "encoding": "utf-8"
    },

    "smpp": {
        "host": "localhost",
        "port": 2775,
        "system_id": "smppclient1",
        "password": "password",
        "system_type": "",
        "bind_type": "transceiver",

        "source_addr": "",

        "addr_ton": 5,
        "addr_npi": 0,

        "dest_ton": 1,
        "dest_npi": 1,

        "data_coding": 0,
        "registered_delivery": 1,

        "connection_timeout": 30,
        "socket_timeout": 30,

        "enquire_link_interval": 30,
        "reconnect_interval": 10,
        "max_reconnect_attempts": 0
    },

    "processing": {
        "batch_size": 100,
        "rate_limit_per_second": 50,
        "max_retry": 3,
        "retry_interval_seconds": 5,

        "min_msisdn_length": 8,
        "max_msisdn_length": 15,

        "archive_after_success": true,
        "delete_after_archive": false,
        "move_to_failed_on_error": true
    },

    "validation": {
        "expected_header": [
            "MSISDN",
            "Message"
        ],
        "min_msisdn_length": 8,
        "max_msisdn_length": 15,
        "max_message_length": 1600
    },

    "logging": {
        "level": "INFO",
        "console": true,
        "file": true,
        "rotation": {
            "max_file_size_mb": 50,
            "backup_count": 10
        }
    },

    "delivery_report": {
        "enabled": true,
        "wait_timeout_seconds": 300,
        "delimiter": ",",
        "write_header": true,
        "output_file_prefix": "DLR"
    },

    "paths": {
        "input_directory": "./input",
        "archive_directory": "./archive",
        "failed_directory": "./failed",
        "delivery_report_directory": "./delivery_reports",

        "invalid_record_file": "./failed/invalid_records.csv",
        "message_mapping_file": "./data/message_mapping.csv",

        "log_directory": "./logs",
        "log_file": "sms_sender.log"
    }
}
